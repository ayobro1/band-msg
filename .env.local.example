# ─────────────────────────────────────────────────────────────────────────────
# Band Messaging – Environment Variables
# Copy this file to .env.local for local development.
# In Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Convex deployment URL.
# Get this from the Convex dashboard (convex.dev) or by running:
#   npx convex deploy
# It looks like: https://happy-animal-123.convex.cloud
CONVEX_URL=

# Whether session/CSRF cookies use the Secure flag.
# Set to "true" in production (Vercel). Set to "false" only for local HTTP dev.
# "auto" derives the value from NODE_ENV (production → true, else → false).
AUTH_COOKIE_SECURE=true

# ── SET AUTOMATICALLY BY VERCEL (do not add manually) ─────────────────────────
# NODE_ENV=production
# VERCEL=1
